# =============================================================================
# Pizzamaker Local - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Docker Compose reads .env automatically from the project root.
# All variables below have sensible defaults in docker-compose.yml;
# you only need to override the ones you want to change.
# =============================================================================

# --- General ----------------------------------------------------------------

# Path to the cloned microservice repos (default: ./repos)
# REPOS_DIR=./repos

# Log level for all Go services (debug | info | warn | error)
# LOG_LEVEL=info

# --- AI Provider (recipe-mcp-server) ---------------------------------------

# Which LLM backend to use: ollama | gemini | external | mock
AI_PROVIDER=gemini

# Max HTTP timeout for LLM calls in milliseconds
# AI_HTTP_TIMEOUT_MS=60000

# How many attempts before giving up on a valid response
# AI_GENERATION_MAX_ATTEMPTS=2

# -- Gemini (recommended for local testing) --
# Get a free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# -- Ollama (local LLM, requires Docker disk space) --
# OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_MODEL=llama3.2:3b

# -- External (generic OpenAI-compatible API) --
# EXTERNAL_API_BASE_URL=
# EXTERNAL_API_KEY=

# --- recipe-manager ---------------------------------------------------------

# Timeout for recipe-manager -> recipe-mcp-server HTTP calls (ms)
# MCP_CLIENT_TIMEOUT_MS=60000

# --- Exposed Ports ----------------------------------------------------------
# Change these if you have port conflicts on your machine.

# PIZZAMAKER_FE_PORT=3000
# TRAEFIK_HTTP_PORT=8000
# TRAEFIK_HTTPS_PORT=8443
# TRAEFIK_DASHBOARD_PORT=8080
# MYSQL_PORT=3306
# JAEGER_UI_PORT=16686
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3001
# ELASTICSEARCH_PORT=9200
# KIBANA_PORT=5601

# --- Credentials -----------------------------------------------------------
# Default dev credentials - change in production.

# GRAFANA_PASSWORD=admin
# REDIS_PASSWORD=pizzamaker_redis_2024
